.DS_Store

# Python
__pycache__/
.pytest_cache/
*.py[cod]
*.egg-info/
build/
dist/

# Local render/probe output
tmp/
.codex_external/

# Native build outputs
native/build/
native/**/build/
*.o
*.a
*.so
*.dylib
*.dll
*.exe

# Heavy generated solver/table payloads. Keep JSON/CSV/TEX result evidence visible.
/data/generated/**/*.bin
/data/generated/**/*.partial
/results/**/*.bin
/results/**/*.partial
/results/**/*.tar
/results/**/*.tar.gz
/results/**/*.zip

# Split H48 table parts (e.g. h48h7.bin.part00000), multi-GiB binary payloads.
*.bin.part*

# Quarantined out-of-scope cloud/fast-target result artifacts (Phase-2 P2-3/P2-8).
# Multi-GiB; not cited by any thesis table. See archive/README.md.
/archive/

# Agent orchestration / workflow scripts (tooling, not thesis content)
/.audit_workflow.js
/.impl_phase1.js
/.impl_phase2.js

# LaTeX build intermediates generated by the required root-level latexmk command
*.aux
*.bbl
*.blg
*.fdb_latexmk
*.fls
*.log
*.out
*.toc
*.xdv
/main.pdf
